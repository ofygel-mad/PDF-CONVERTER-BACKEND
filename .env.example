# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=PDF Converter API
ENVIRONMENT=production            # development | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
API_PORT=8000

# Comma-separated list of frontend origins allowed by CORS
# Set to the URL where your frontend is served
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=pdf_converter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433                # host port (container always uses 5432)

# DATABASE_URL is built from the above inside docker-compose; override only if
# you connect to an external PostgreSQL instance
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Celery ───────────────────────────────────────────────────────────────────
# prefork = production multi-process; solo = single-process (dev / Windows)
CELERY_POOL=prefork
CELERY_CONCURRENCY=2

# ─── MinIO (object storage) ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW=raw-documents
MINIO_BUCKET_EXPORTS=excel-exports

# ─── Azure Document Intelligence (optional OCR) ───────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
